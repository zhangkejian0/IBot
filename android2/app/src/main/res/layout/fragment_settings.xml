<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/settings"
        app:titleTextColor="@color/text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/settings_display" />

            <LinearLayout style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsLabel"
                    android:text="@string/settings_debug_mode" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_debug"
                    style="@style/SettingsSwitch" />
            </LinearLayout>

            <TextView
                style="@style/SettingsSectionHeader"
                android:layout_marginTop="12dp"
                android:text="@string/settings_identity_section" />

            <LinearLayout
                android:id="@+id/row_owner"
                style="@style/SettingsRow"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/SettingsLabel"
                        android:layout_width="match_parent"
                        android:layout_weight="0"
                        android:text="@string/settings_owner" />

                    <TextView
                        android:id="@+id/owner_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_face_enrollment"
                style="@style/SettingsRowClickable">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/SettingsLabel"
                        android:layout_width="match_parent"
                        android:layout_weight="0"
                        android:text="@string/settings_know_me" />

                    <TextView
                        android:id="@+id/know_me_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_friends"
                style="@style/SettingsRowClickable"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/SettingsLabel"
                        android:layout_width="match_parent"
                        android:layout_weight="0"
                        android:text="@string/settings_my_friends" />

                    <TextView
                        android:id="@+id/friends_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsLabel"
                    android:text="@string/settings_identity_enable" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_identity"
                    style="@style/SettingsSwitch" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_reset_owner"
                style="@style/SettingsRowClickable"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/SettingsLabel"
                        android:layout_width="match_parent"
                        android:layout_weight="0"
                        android:text="@string/settings_reset_owner" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_reset_owner_hint"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/identity_model_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="4dp"
                android:paddingTop="6dp"
                android:paddingEnd="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                style="@style/SettingsSectionHeader"
                android:layout_marginTop="12dp"
                android:text="@string/settings_recognition" />

            <LinearLayout style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsLabel"
                    android:text="@string/settings_face" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_face"
                    style="@style/SettingsSwitch" />
            </LinearLayout>

            <LinearLayout style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsLabel"
                    android:text="@string/settings_hand" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_hand"
                    style="@style/SettingsSwitch" />
            </LinearLayout>

            <LinearLayout style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsLabel"
                    android:text="@string/settings_pose" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_pose"
                    style="@style/SettingsSwitch" />
            </LinearLayout>

            <TextView
                style="@style/SettingsSectionHeader"
                android:layout_marginTop="12dp"
                android:text="@string/settings_voice" />

            <LinearLayout style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsLabel"
                    android:text="@string/settings_voice_enabled" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_voice"
                    style="@style/SettingsSwitch" />
            </LinearLayout>

            <LinearLayout style="@style/SettingsRow">
                <TextView
                    style="@style/SettingsLabel"
                    android:text="@string/settings_wake_word" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_wake_word"
                    style="@style/SettingsSwitch" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_base_debug"
                style="@style/SettingsRowClickable"
                android:layout_marginTop="12dp">

                <TextView
                    style="@style/SettingsLabel"
                    android:layout_weight="1"
                    android:text="@string/settings_base_debug" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_detail"
                style="@style/SettingsRowClickable">

                <TextView
                    style="@style/SettingsLabel"
                    android:layout_weight="1"
                    android:text="@string/settings_detail" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
