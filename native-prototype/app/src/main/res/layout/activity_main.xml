<?xml version="1.0" encoding="utf-8"?>
<!--
  原型布局:WebView 全屏(显示表情页) + 右上角调试浮层(显示推理延迟/帧率/人脸数)。
  关键:相机预览不显示(陪伴机器人只显示虚拟表情),相机在后台线程取流推理。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- 表情页 WebView:复用现有 assets/html/dist 产物 -->
    <WebView
        android:id="@+id/faceWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 调试浮层:实时显示原生后台推理的延迟/帧率/人脸数,用于对比判断 -->
    <TextView
        android:id="@+id/debugOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:padding="10dp"
        android:background="#80000000"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:text="初始化中…" />

    <!-- 未授权时提示 -->
    <TextView
        android:id="@+id/permissionHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone"
        android:text="需要相机权限,请授权后重启" />

</FrameLayout>
